#!/bin/sh
set -eu
cd "$(dirname "$0")/.."

usage() {
	cat >&2 <<'EOF'
usage: scripts/performance-audit-derive-manifest --before DIR --after DIR --output PATH

Derive per-row timing gates from two complete captures of the same baseline.
The --before capture is baseline role A and --after is baseline role B.
The emitted immutable manifest is version 2 with independent A/B timing
envelopes.
Capture fingerprints cover metadata.txt, capture-facts.tsv, environment.tsv,
and the five raw family files (not summaries or profiles); the comparator binds
the selected baseline role to its exact fingerprint.
EOF
}

before= after= output=
while [ "$#" -gt 0 ]; do
	case "$1" in
	--before) [ "$#" -ge 2 ] || { usage; exit 2; }; before=$2; shift 2 ;;
	--after) [ "$#" -ge 2 ] || { usage; exit 2; }; after=$2; shift 2 ;;
	--output) [ "$#" -ge 2 ] || { usage; exit 2; }; output=$2; shift 2 ;;
	-h|--help) usage; exit 0 ;;
	*) usage; exit 2 ;;
	esac
done
[ -n "$before" ] && [ -n "$after" ] && [ -n "$output" ] || { usage; exit 2; }
[ ! -e "$output" ] || { printf 'derive-manifest: refusing to overwrite: %s\n' "$output" >&2; exit 1; }

metadata_value() { awk -F= -v wanted="$2" '$1 == wanted { print substr($0, index($0, "=") + 1); exit }' "$1"; }
capture_fingerprint() {
	dir=$1
	{
		printf 'FILE metadata.txt\n'; cat "$dir/metadata.txt"
		printf 'FILE capture-facts.tsv\n'; cat "$dir/capture-facts.tsv"
		printf 'FILE environment.tsv\n'; cat "$dir/environment.tsv"
		for family in scenario_ember_run recursive_fibonacci sparse_grid_neighbors runtime_modes compiler_256kib; do
			printf 'FILE %s.raw.txt\n' "$family"
			cat "$dir/$family.raw.txt"
		done
	} | shasum -a 256 | awk '{print $1}'
}
for dir in "$before" "$after"; do
	[ -d "$dir" ] || { printf 'derive-manifest: missing capture: %s\n' "$dir" >&2; exit 2; }
	[ -f "$dir/COMPLETE" ] && [ ! -e "$dir/INCOMPLETE" ] || { printf 'derive-manifest: capture is incomplete: %s\n' "$dir" >&2; exit 1; }
	[ -r "$dir/metadata.txt" ] || { printf 'derive-manifest: metadata.txt is required: %s\n' "$dir" >&2; exit 1; }
	[ -r "$dir/capture-facts.tsv" ] || { printf 'derive-manifest: capture-facts.tsv is required: %s\n' "$dir" >&2; exit 1; }
	[ -r "$dir/environment.tsv" ] || { printf 'derive-manifest: environment.tsv is required: %s\n' "$dir" >&2; exit 1; }
done
for key in source_fingerprint environment_fingerprint commit samples benchtime; do
	b=$(metadata_value "$before/metadata.txt" "$key")
	a=$(metadata_value "$after/metadata.txt" "$key")
	[ -n "$b" ] && [ "$b" = "$a" ] || { printf 'derive-manifest: incompatible %s metadata\n' "$key" >&2; exit 1; }
done
samples=$(metadata_value "$before/metadata.txt" samples)
case "$samples" in ''|*[!0-9]*) printf '%s\n' 'derive-manifest: samples must be a positive integer' >&2; exit 1 ;; esac
[ "$samples" -gt 0 ] || { printf '%s\n' 'derive-manifest: samples must be positive' >&2; exit 1; }
before_capture_fingerprint=$(capture_fingerprint "$before")
after_capture_fingerprint=$(capture_fingerprint "$after")
[ "$before_capture_fingerprint" != "$after_capture_fingerprint" ] || {
	printf '%s\n' 'derive-manifest: baseline A and B capture fingerprints must differ' >&2
	exit 1
}
environment_sha256() {
	shasum -a 256 "$1/environment.tsv" | awk '{print $1}'
}
before_environment_sha256=$(environment_sha256 "$before")
after_environment_sha256=$(environment_sha256 "$after")
[ "$before_environment_sha256" = "$after_environment_sha256" ] || {
	printf '%s\n' 'derive-manifest: incompatible environment.tsv fingerprints' >&2
	exit 1
}

families='scenario_ember_run:scenario_ember_run:runtime
recursive_fibonacci:recursive_fibonacci:runtime
sparse_grid_neighbors:sparse_grid_neighbors:runtime
runtime_modes:runtime_modes:runtime
compiler_256kib:compiler_256kib:compiler'
tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/ember-derive-manifest.XXXXXX")
cleanup() { rm -rf "$tmp_dir"; }
trap cleanup EXIT HUP INT TERM
for spec in $families; do
	oldIFS=$IFS; IFS=:; set -- $spec; IFS=$oldIFS
	family=$1
	[ -r "$before/$family.raw.txt" ] && [ -r "$after/$family.raw.txt" ] || { printf 'derive-manifest: missing raw family: %s\n' "$family" >&2; exit 1; }
	scripts/bench-summary --format samples-tsv --before "$before/$family.raw.txt" >"$tmp_dir/$family.before.tsv"
	scripts/bench-summary --format samples-tsv --before "$after/$family.raw.txt" >"$tmp_dir/$family.after.tsv"
	[ -s "$tmp_dir/$family.before.tsv" ] && [ -s "$tmp_dir/$family.after.tsv" ] || { printf 'derive-manifest: empty raw family: %s\n' "$family" >&2; exit 1; }
done

mkdir -p "$(dirname "$output")"
out_tmp=$output.tmp.$$
trap 'rm -f "$out_tmp"; cleanup' EXIT HUP INT TERM
{
	printf 'version=2\n'
	printf 'samples=%s\n' "$samples"
	printf 'baseline_source_fingerprint=%s\n' "$(metadata_value "$before/metadata.txt" source_fingerprint)"
	printf 'baseline_environment_fingerprint=%s\n' "$(metadata_value "$before/metadata.txt" environment_fingerprint)"
	printf 'baseline_environment_sha256=%s\n' "$before_environment_sha256"
	printf 'baseline_commit=%s\n' "$(metadata_value "$before/metadata.txt" commit)"
	printf 'baseline_benchtime=%s\n' "$(metadata_value "$before/metadata.txt" benchtime)"
	printf 'baseline_a_capture_role=a\n'
	printf 'baseline_a_capture_fingerprint=%s\n' "$before_capture_fingerprint"
	printf 'baseline_b_capture_role=b\n'
	printf 'baseline_b_capture_fingerprint=%s\n' "$after_capture_fingerprint"
	printf 'row\tfamily\tname\tns_max_ratio_a\tns_max_ratio_b\tbytes_max\tallocs_max\n'
} >"$out_tmp"

for spec in $families; do
	oldIFS=$IFS; IFS=:; set -- $spec; IFS=$oldIFS
	family=$1
	set_name=$3
	awk -F '\t' -v family="$family" -v set_name="$set_name" -v samples="$samples" '
function median(values, count, i, j, v) {
    delete sorted
    for (i = 1; i <= count; i++) sorted[i] = values[i]
    for (i = 2; i <= count; i++) { v = sorted[i]; j = i - 1; while (j > 0 && sorted[j] > v) { sorted[j + 1] = sorted[j]; j-- } sorted[j + 1] = v }
    if (count % 2) return sorted[(count + 1) / 2]
    return (sorted[count / 2] + sorted[count / 2 + 1]) / 2
}
function absolute(value) { return value < 0 ? -value : value }
FNR == NR { before_rows[$1] = 1; before_count[$1]++; i = before_count[$1]; before_ns[$1,i] = $3; before_bytes[$1,i] = $4; before_allocs[$1,i] = $5; next }
{ after_rows[$1] = 1; after_count[$1]++; i = after_count[$1]; after_ns[$1,i] = $3; after_bytes[$1,i] = $4; after_allocs[$1,i] = $5 }
END {
    for (row in before_rows) {
        if (!(row in after_rows)) { printf "derive-manifest: missing row %s/%s\n", family, row > "/dev/stderr"; bad = 1; continue }
        if (before_count[row] != samples || after_count[row] != samples) { printf "derive-manifest: incomplete samples %s/%s\n", family, row > "/dev/stderr"; bad = 1; continue }
        for (i = 1; i <= samples; i++) if (before_ns[row,i] <= 0 || after_ns[row,i] <= 0 || before_bytes[row,i] < 0 || after_bytes[row,i] < 0 || before_allocs[row,i] < 0 || after_allocs[row,i] < 0) { printf "derive-manifest: incomplete metrics %s/%s\n", family, row > "/dev/stderr"; bad = 1 }
        rows[row] = 1
    }
    for (row in after_rows) if (!(row in before_rows)) { printf "derive-manifest: extra row %s/%s\n", family, row > "/dev/stderr"; bad = 1 }
    if (bad) exit 1
	for (row in rows) {
		delete pooled; delete baseline; delete candidate; pooled_count = 0
		bytes_max = 0; allocs_max = 0
		for (i = 1; i <= samples; i++) {
			baseline[i] = before_ns[row,i]; candidate[i] = after_ns[row,i]
			pooled[++pooled_count] = baseline[i]; pooled[++pooled_count] = candidate[i]
			if (before_bytes[row,i] > bytes_max) bytes_max = before_bytes[row,i]
			if (after_bytes[row,i] > bytes_max) bytes_max = after_bytes[row,i]
			if (before_allocs[row,i] > allocs_max) allocs_max = before_allocs[row,i]
			if (after_allocs[row,i] > allocs_max) allocs_max = after_allocs[row,i]
		}
        pooled_median = median(pooled, pooled_count); baseline_median = median(baseline, samples); candidate_median = median(candidate, samples)
        for (i = 1; i <= pooled_count; i++) deviations[i] = absolute(pooled[i] - pooled_median)
        mad = median(deviations, pooled_count); shift = absolute(candidate_median - baseline_median); noise = 1.4826 * mad
        if (shift > noise) noise = shift
        if (noise < 100) noise = 100
		ratio_a = 1 + noise / baseline_median
		ratio_b = 1 + noise / candidate_median
		if (set_name == "scenario_ember_run") {
			if (ratio_a < 1.05) ratio_a = 1.05
			if (ratio_b < 1.05) ratio_b = 1.05
		}
		printf "row\t%s\t%s\t%.17g\t%.17g\t%.17g\t%.17g\n", family, row, ratio_a, ratio_b, bytes_max, allocs_max
    }
}
' "$tmp_dir/$family.before.tsv" "$tmp_dir/$family.after.tsv" >>"$out_tmp" || { rm -f "$out_tmp"; exit 1; }
done

mv "$out_tmp" "$output"
printf 'derived gate manifest: %s\n' "$output"
