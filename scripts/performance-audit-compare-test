#!/bin/sh
set -eu
cd "$(dirname "$0")/.."
root=$(mktemp -d "${TMPDIR:-/tmp}/ember-audit-v2-test.XXXXXX")
cleanup() { rm -rf "$root"; }
trap cleanup EXIT HUP INT TERM
families='scenario_ember_run recursive_fibonacci sparse_grid_neighbors runtime_modes compiler_256kib'
write_capture() {
	dir=$1; env_fingerprint=$2; source_fingerprint=$3; ns=$4; bytes=$5; allocs=$6; wide_ns=${7:-10000}; first_ns=${8:-100}
	rm -rf "$dir"; mkdir -p "$dir"
	{
		printf 'commit=commit-baseline\n'
		printf 'source_fingerprint=%s\n' "$source_fingerprint"
		printf 'environment_fingerprint=%s\n' "$env_fingerprint"
		printf 'benchtime=1ms\nprofiles=0\n'
		printf 'samples=2\n'
	} >"$dir/metadata.txt"
	# Shared acceptance-environment artifact (the real validator writes this exact v1 shape).
	printf 'schema_version\tgo_version\tgoos\tgoarch\tos_build\tcpu_model\tcgo_enabled\tgomaxprocs\tluau_version\tluau_sha256\n' >"$dir/environment.tsv"
	printf '1\tgo1.26.4\tDarwin\tarm64\tDarwin 24.6.0\tApple M1\t0\t1\tnot-applicable\tnot-applicable\n' >>"$dir/environment.tsv"
	printf '%s\n' complete >"$dir/COMPLETE"
	for family in $families; do
		name="BenchmarkShared/row/ember_run-8"
		[ "$family" = compiler_256kib ] && name='BenchmarkCompilerStageMatrix/256KiB/emit-8'
		printf '%s\n' "$name $first_ns ns/op $bytes B/op $allocs allocs/op" >"$dir/$family.raw.txt"
		printf '%s\n' "$name $ns ns/op $bytes B/op $allocs allocs/op" >>"$dir/$family.raw.txt"
		if [ "$family" = scenario_ember_run ]; then
			printf '%s\n' 'BenchmarkScenarioLuau/wide/ember_run-8 10000 ns/op 10 B/op 1 allocs/op' >>"$dir/$family.raw.txt"
			printf '%s\n' "BenchmarkScenarioLuau/wide/ember_run-8 $wide_ns ns/op 10 B/op 1 allocs/op" >>"$dir/$family.raw.txt"
		fi
		summary=-; [ "$family" = compiler_256kib ] || summary="$family.summary.md"
		[ "$summary" = - ] || : >"$dir/$summary"
	done
	{
		printf 'version=1\nsamples=2\nprofiles=0\n'
		printf 'family\tname\traw\tsummary\tcpu_profile\talloc_profile\tprofile_log\n'
		for family in $families; do
			summary=-; [ "$family" = compiler_256kib ] || summary="$family.summary.md"
			printf 'family\t%s\t%s.raw.txt\t%s\t%s.cpu.pprof\t%s.alloc.pprof\t%s.profile.log\n' "$family" "$family" "$summary" "$family" "$family" "$family"
		done
		for family in $families; do
			scripts/bench-summary --format tsv --before "$dir/$family.raw.txt" | awk -F '\t' -v family="$family" '{ print "row\t" family "\t" $1 }'
		done
	} >"$dir/capture-facts.tsv"
}

run_fail() {
	needle=$1; shift; out=$root/failure
	if "$@" >"$out" 2>&1; then printf 'expected failure: %s\n' "$needle" >&2; exit 1; fi
	grep -F "$needle" "$out" >/dev/null || { cat "$out" >&2; exit 1; }
}

write_capture "$root/base1" env source 100 10 1
write_capture "$root/base2" env source 101 10 1
scripts/performance-audit-derive-manifest --before "$root/base1" --after "$root/base2" --output "$root/gates.tsv" >/dev/null
grep -F 'baseline_a_capture_role=a' "$root/gates.tsv" >/dev/null
grep -F 'baseline_b_capture_role=b' "$root/gates.tsv" >/dev/null
grep -F 'baseline_a_capture_fingerprint=' "$root/gates.tsv" >/dev/null
grep -F 'baseline_b_capture_fingerprint=' "$root/gates.tsv" >/dev/null
grep -F 'row	family	name	ns_max_ratio_a	ns_max_ratio_b	bytes_max	allocs_max' "$root/gates.tsv" >/dev/null
scripts/performance-audit-compare --before "$root/base1" --after "$root/base2" --manifest "$root/gates.tsv" >"$root/slower-baseline"
grep -F 'result: PASS' "$root/slower-baseline" >/dev/null
run_fail 'capture fingerprint mismatch' scripts/performance-audit-compare --before "$root/base2" --after "$root/base1" --manifest "$root/gates.tsv" --baseline-role a
scripts/performance-audit-compare --before "$root/base2" --after "$root/base1" --manifest "$root/gates.tsv" --baseline-role b >"$root/role-b-pass"
grep -F 'result: PASS' "$root/role-b-pass" >/dev/null
run_fail 'capture fingerprint mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/base2" --manifest "$root/gates.tsv" --baseline-role b

# Directional regression: A is slower than B. Independent role-specific timing
# envelopes must admit A->B and the reverse B->A role selection.
write_capture "$root/directional-a" env source 1000 10 1
write_capture "$root/directional-b" env source 900 10 1
scripts/performance-audit-derive-manifest --before "$root/directional-a" --after "$root/directional-b" --output "$root/directional-gates.tsv" >/dev/null
scripts/performance-audit-compare --before "$root/directional-a" --after "$root/directional-b" --manifest "$root/directional-gates.tsv" --baseline-role a >"$root/directional-a-pass"
grep -F 'result: PASS' "$root/directional-a-pass" >/dev/null
scripts/performance-audit-compare --before "$root/directional-b" --after "$root/directional-a" --manifest "$root/directional-gates.tsv" --baseline-role b >"$root/directional-b-pass"
grep -F 'result: PASS' "$root/directional-b-pass" >/dev/null
awk -F '\t' '$1 == "row" && $2 == "scenario_ember_run" && $3 == "BenchmarkShared/row/ember_run" { exit !($4 > 1 && $5 > 1 && $4 != $5) }' "$root/directional-gates.tsv"

run_fail 'refusing to overwrite' scripts/performance-audit-derive-manifest --before "$root/base1" --after "$root/base2" --output "$root/gates.tsv"

write_capture "$root/precision-base1" env source 3080499 10 1 10000 3080499
write_capture "$root/precision-base2" env source 3262773 10 1 10000 3262773
scripts/performance-audit-derive-manifest --before "$root/precision-base1" --after "$root/precision-base2" --output "$root/precision-gates.tsv" >/dev/null
scripts/performance-audit-compare --before "$root/precision-base1" --after "$root/precision-base2" --manifest "$root/precision-gates.tsv" >"$root/precision-pass"
grep -F 'result: PASS' "$root/precision-pass" >/dev/null

shared_gate=$(awk -F '\t' '$1 == "row" && $2 == "scenario_ember_run" && $3 == "BenchmarkShared/row/ember_run" { print $4 }' "$root/gates.tsv")
wide_gate=$(awk -F '\t' '$1 == "row" && $2 == "scenario_ember_run" && $3 == "BenchmarkScenarioLuau/wide/ember_run" { print $4 }' "$root/gates.tsv")
awk -v shared="$shared_gate" -v wide="$wide_gate" 'BEGIN { exit !(shared > wide) }'
write_capture "$root/isolation" env candidate 150 10 1 12000
run_fail 'result: FAIL' scripts/performance-audit-compare --before "$root/base1" --after "$root/isolation" --manifest "$root/gates.tsv"
grep -F 'BenchmarkShared/row/ember_run' "$root/failure" | grep -F 'ns/op' | grep -F 'pass' >/dev/null
grep -F 'BenchmarkScenarioLuau/wide/ember_run' "$root/failure" | grep -F 'ns/op' | grep -F 'fail' >/dev/null

write_capture "$root/allocation-base1" env source 100 10 1
write_capture "$root/allocation-base2" env source 101 11 2
scripts/performance-audit-derive-manifest --before "$root/allocation-base1" --after "$root/allocation-base2" --output "$root/allocation-gates.tsv" >/dev/null
write_capture "$root/allocation-candidate" env candidate 90 11 2
scripts/performance-audit-compare --before "$root/allocation-base1" --after "$root/allocation-candidate" --manifest "$root/allocation-gates.tsv" >"$root/allocation-pass"
grep -F 'result: PASS' "$root/allocation-pass" >/dev/null
write_capture "$root/allocation-candidate" env candidate 90 12 3
run_fail 'result: FAIL' scripts/performance-audit-compare --before "$root/allocation-base1" --after "$root/allocation-candidate" --manifest "$root/allocation-gates.tsv"

write_capture "$root/candidate" env candidate 90 10 1
scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv" >"$root/pass"
grep -F 'result: PASS' "$root/pass" >/dev/null
awk -F '\t' '$1 == "row" && $2 == "scenario_ember_run" && $3 == "BenchmarkScenarioLuau/wide/ember_run" { found=1 } END { exit !found }' "$root/gates.tsv"
printf '%s\n' 'environment mutation' >>"$root/candidate/environment.tsv"
run_fail 'environment.tsv mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
write_capture "$root/candidate" env candidate 90 10 1
printf '%s\n' '# mutated after gate derivation' >>"$root/base1/scenario_ember_run.raw.txt"
run_fail 'capture fingerprint mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
write_capture "$root/base1" env source 100 10 1
run_fail 'missing gate manifest' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/missing-gates.tsv"
rm "$root/candidate/COMPLETE"
run_fail 'incomplete capture' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
printf '%s\n' 'BenchmarkScenarioLuau/extra/ember_run-8 90 ns/op 10 B/op 1 allocs/op' >>"$root/candidate/scenario_ember_run.raw.txt"
touch "$root/candidate/COMPLETE"
run_fail 'capture row inventory mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
write_capture "$root/candidate" env candidate 90 10 1
sed -i.bak '/^row\tscenario_ember_run\tBenchmarkShared\/row\/ember_run$/d' "$root/candidate/capture-facts.tsv"
rm -f "$root/candidate/capture-facts.tsv.bak"
run_fail 'capture row inventory mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"

write_capture "$root/candidate" env candidate 1000 10 1
sed -i.bak '1s/ 100 ns\/op/ 1000 ns\/op/' "$root/candidate/scenario_ember_run.raw.txt"
rm -f "$root/candidate/scenario_ember_run.raw.txt.bak"
run_fail 'result: FAIL' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"

write_capture "$root/candidate" env candidate 90 11 2
run_fail 'fail' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"

write_capture "$root/zero-base1" env source 100 0 0
write_capture "$root/zero-base2" env source 101 0 0
scripts/performance-audit-derive-manifest --before "$root/zero-base1" --after "$root/zero-base2" --output "$root/zero-gates.tsv" >/dev/null
write_capture "$root/candidate" env candidate 90 0 0
scripts/performance-audit-compare --before "$root/zero-base1" --after "$root/candidate" --manifest "$root/zero-gates.tsv" >"$root/zero"
grep -F 'result: PASS' "$root/zero" >/dev/null
write_capture "$root/candidate" env candidate 90 1 1
run_fail 'fail' scripts/performance-audit-compare --before "$root/zero-base1" --after "$root/candidate" --manifest "$root/zero-gates.tsv"

write_capture "$root/candidate" env candidate 90 10 1
touch "$root/candidate/INCOMPLETE"
run_fail 'incomplete capture' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
rm "$root/candidate/INCOMPLETE"

for family in $families; do
	: >"$root/candidate/$family.cpu.pprof"
	: >"$root/candidate/$family.alloc.pprof"
	: >"$root/candidate/$family.profile.log"
done
sed -i.bak 's/^profiles=0$/profiles=1/' "$root/candidate/capture-facts.tsv"
rm -f "$root/candidate/runtime_modes.alloc.pprof.bak"
rm "$root/candidate/runtime_modes.alloc.pprof"
run_fail 'missing profile artifact' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
rm -f "$root/candidate/capture-facts.tsv.bak"

printf '%s\n' 'samples=3' >>"$root/candidate/capture-facts.tsv"
run_fail 'sample mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"

write_capture "$root/candidate" changed candidate 90 10 1
run_fail 'environment mismatch' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"
write_capture "$root/candidate" env candidate 90 10 1
cp "$root/gates.tsv" "$root/malformed-metadata.tsv"
sed -i.bak 's/^samples=2$/samples=bad/' "$root/malformed-metadata.tsv"
rm -f "$root/malformed-metadata.tsv.bak"
run_fail 'invalid gate manifest sample count' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/malformed-metadata.tsv"
cp "$root/gates.tsv" "$root/duplicate-metadata.tsv"
printf '%s\n' 'samples=2' >>"$root/duplicate-metadata.tsv"
run_fail 'invalid gate manifest samples' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/duplicate-metadata.tsv"
cp "$root/gates.tsv" "$root/v1-manifest.tsv"
sed -i.bak 's/^version=2$/version=1/' "$root/v1-manifest.tsv"
rm -f "$root/v1-manifest.tsv.bak"
run_fail 'invalid gate manifest metadata' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/v1-manifest.tsv"
cp "$root/gates.tsv" "$root/extra-column.tsv"
awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 != "family" && !done++ { $8="unexpected" } { print }' "$root/extra-column.tsv" >"$root/extra-column.tmp"
mv "$root/extra-column.tmp" "$root/extra-column.tsv"
run_fail 'invalid gate manifest rows' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/extra-column.tsv"
cp "$root/gates.tsv" "$root/extra-header-column.tsv"
awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 == "family" && !done++ { $8="unexpected" } { print }' "$root/extra-header-column.tsv" >"$root/extra-header-column.tmp"
mv "$root/extra-header-column.tmp" "$root/extra-header-column.tsv"
run_fail 'invalid gate manifest rows' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/extra-header-column.tsv"
for malformed in missing duplicate nonnumeric below-one; do
	cp "$root/gates.tsv" "$root/role-b-$malformed.tsv"
	case "$malformed" in
	missing) awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 != "family" && !done++ { $5="" } { print }' "$root/role-b-$malformed.tsv" >"$root/role-b-$malformed.tmp" ;;
	duplicate) awk -F '\t' 'BEGIN { OFS="\t" } { print; if ($1 == "row" && $2 != "family" && !done++) saved=$0 } END { print saved }' "$root/role-b-$malformed.tsv" >"$root/role-b-$malformed.tmp" ;;
	nonnumeric) awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 != "family" && !done++ { $5="bad" } { print }' "$root/role-b-$malformed.tsv" >"$root/role-b-$malformed.tmp" ;;
	below-one) awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 != "family" && !done++ { $5="0.5" } { print }' "$root/role-b-$malformed.tsv" >"$root/role-b-$malformed.tmp" ;;
	esac
	mv "$root/role-b-$malformed.tmp" "$root/role-b-$malformed.tsv"
	run_fail 'invalid gate manifest rows' scripts/performance-audit-compare --before "$root/base2" --after "$root/candidate" --baseline-role b --manifest "$root/role-b-$malformed.tsv"
done
printf 'row\tscenario_ember_run\tBenchmarkShared/row/ember_run\t1.1\t1.1\texact\texact\n' >>"$root/gates.tsv"
run_fail 'invalid gate manifest rows' scripts/performance-audit-compare --before "$root/base1" --after "$root/candidate" --manifest "$root/gates.tsv"

cp "$root/gates.tsv" "$root/threshold-gates.tsv"
# Remove the deliberately appended duplicate from the general malformed test.
sed -i.bak '$d' "$root/threshold-gates.tsv"
rm -f "$root/threshold-gates.tsv.bak"
awk -F '\t' 'BEGIN { OFS="\t" } $1 == "row" && $2 != "family" { $4="1.1"; $5="1.1" } { print }' "$root/threshold-gates.tsv" >"$root/threshold-gates.tmp"
mv "$root/threshold-gates.tmp" "$root/threshold-gates.tsv"
write_capture "$root/threshold-candidate" env candidate 110 10 1
scripts/performance-audit-compare --before "$root/base1" --after "$root/threshold-candidate" --baseline-role a --manifest "$root/threshold-gates.tsv" >"$root/threshold-a-pass"
grep -F 'result: PASS' "$root/threshold-a-pass" >/dev/null
write_capture "$root/threshold-candidate" env candidate 120 10 1
scripts/performance-audit-compare --before "$root/base1" --after "$root/threshold-candidate" --baseline-role a --manifest "$root/threshold-gates.tsv" >"$root/threshold-a-exact-pass"
grep -F 'result: PASS' "$root/threshold-a-exact-pass" >/dev/null
write_capture "$root/threshold-candidate" env candidate 122 10 1
run_fail 'result: FAIL' scripts/performance-audit-compare --before "$root/base1" --after "$root/threshold-candidate" --baseline-role a --manifest "$root/threshold-gates.tsv"
write_capture "$root/threshold-candidate" env candidate 121.1 10 1
scripts/performance-audit-compare --before "$root/base2" --after "$root/threshold-candidate" --baseline-role b --manifest "$root/threshold-gates.tsv" >"$root/threshold-b-pass"
grep -F 'result: PASS' "$root/threshold-b-pass" >/dev/null
write_capture "$root/threshold-candidate" env candidate 123 10 1
run_fail 'result: FAIL' scripts/performance-audit-compare --before "$root/base2" --after "$root/threshold-candidate" --baseline-role b --manifest "$root/threshold-gates.tsv"

write_capture "$root/base2" env changed 101 10 1
run_fail 'incompatible source_fingerprint' scripts/performance-audit-derive-manifest --before "$root/base1" --after "$root/base2" --output "$root/bad-gates.tsv"
write_capture "$root/base2" env source 101 10 1
sed -i.bak 's/^benchtime=1ms$/benchtime=5s/' "$root/base2/metadata.txt"
rm -f "$root/base2/metadata.txt.bak"
run_fail 'incompatible benchtime' scripts/performance-audit-derive-manifest --before "$root/base1" --after "$root/base2" --output "$root/bad-benchtime-gates.tsv"

printf '%s\n' 'performance-audit-compare-test: ok'
