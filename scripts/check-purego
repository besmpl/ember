#!/bin/sh
set -eu

cd "$(dirname "$0")/.."

CGO_ENABLED=0 go build ./...
CGO_ENABLED=0 go test ./...

# Run the structural scanner explicitly as a focused policy check. The full
# test above also runs it, but this keeps the boundary independently visible
# to callers and CI logs.
go test -run '^TestPureGoBoundary$' .

cgo_packages="$(CGO_ENABLED=1 go list -f '{{if .CgoFiles}}{{.ImportPath}}: {{join .CgoFiles ", "}}{{end}}' ./...)"
if [ -n "$cgo_packages" ]; then
	printf '%s\n' "repository packages report CgoFiles with CGO_ENABLED=1:" >&2
	printf '%s\n' "$cgo_packages" >&2
	exit 1
fi

foreign_files="$(find . -type f \( \
	-name '*.c' -o -name '*.cc' -o -name '*.cpp' -o -name '*.cxx' \
	-o -name '*.m' -o -name '*.mm' -o -name '*.h' -o -name '*.hh' \
	-o -name '*.hpp' -o -name '*.hxx' -o -name '*.a' -o -name '*.o' \
	-o -name '*.obj' -o -name '*.so' -o -name '*.dylib' -o -name '*.dll' \
	-o -name '*.lib' -o -name '*.syso' -o -name '*.S' \
\) ! -path './.git/*' ! -path './testdata/purego/*' -print)"
if [ -n "$foreign_files" ]; then
	printf '%s\n' 'repository contains foreign source or object files:' >&2
	printf '%s\n' "$foreign_files" >&2
	exit 1
fi

artifact_dir="$(mktemp -d "${TMPDIR:-/tmp}/ember-purego.XXXXXX")"
trap 'rm -rf "$artifact_dir"' EXIT HUP INT TERM
test_binary="$artifact_dir/ember.test"
CGO_ENABLED=0 go test -c -o "$test_binary" .

go tool nm "$test_binary" > "$artifact_dir/symbols.txt"
# Purego and its platform loader symbols are intentional at the structurally
# reviewed prepared-native seam. CGO_ENABLED=0 and the CgoFiles inventory above
# remain the authoritative prohibition on cgo-generated code.
foreign_symbols="$(awk '
BEGIN {
	marker_count = split("runtime/cgo _cgoexp_ _cgo_gotypes .cgo2. plugin.open loadlibrary", markers)
}
{
	symbol = tolower($NF)
	for (i = 1; i <= marker_count; i++) {
		if (markers[i] != "" && index(symbol, markers[i]) != 0) {
			print
			break
		}
	}
}
' "$artifact_dir/symbols.txt")"
if [ -n "$foreign_symbols" ]; then
	printf '%s\n' 'linked test binary contains forbidden cgo/plugin symbols:' >&2
	printf '%s\n' "$foreign_symbols" >&2
	exit 1
fi

EMBER_PUREGO_LINKED_BINARY="$test_binary" CGO_ENABLED=0 \
	go test -run '^TestPureGoLinkedBinary$' .
