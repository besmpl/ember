#!/bin/sh
set -eu

cd "$(dirname "$0")/.."

mode=cross
binary=
while [ "$#" -gt 0 ]; do
	case "$1" in
		--cross) mode=cross; shift ;;
		--native) mode=native; shift ;;
		--binary) [ "$#" -ge 2 ] || { printf '%s\n' 'check-machine-backend: missing --binary value' >&2; exit 2; }; binary=$2; shift 2 ;;
		*) printf 'check-machine-backend: unknown option: %s\n' "$1" >&2; exit 2 ;;
	esac
done

tmp=
if [ -z "$binary" ]; then
	tmp="$(mktemp -d "${TMPDIR:-/tmp}/ember-machine-backend.XXXXXX")"
	trap 'rm -rf "$tmp"' EXIT HUP INT TERM
	CGO_ENABLED=0 GOOS=darwin GOARCH=arm64 go test -c -o "$tmp/darwin-arm64.test" .
	CGO_ENABLED=0 GOOS=linux GOARCH=arm64 go test -c -o "$tmp/linux-arm64.test" .
	"$0" --cross --binary "$tmp/darwin-arm64.test"
	"$0" --cross --binary "$tmp/linux-arm64.test"
	if [ "$mode" = native ]; then
		[ "$(go env GOOS)/$(go env GOARCH)" = darwin/arm64 ] || { printf '%s\n' 'check-machine-backend: native mode requires darwin/arm64' >&2; exit 2; }
		"$0" --native --binary "$tmp/darwin-arm64.test"
	fi
	exit 0
fi

[ -f "$binary" ] && [ ! -L "$binary" ] || { printf '%s\n' 'check-machine-backend: binary must be a regular non-symlink' >&2; exit 2; }
report="$(go run ./cmd/ember-machocheck --binary "$binary")"
printf '%s\n' "$report"

symbols="$(go tool nm -size -type "$binary")"
leaf='github.com/besmpl/ember.runMachineBurstArm64.abi0'
leaf_count="$(printf '%s\n' "$symbols" | awk -v leaf="$leaf" '$NF==leaf{n++} END{print n+0}')"
case "$report" in
	machine\ backend:\ format=macho-arm64*) [ "$leaf_count" -eq 1 ] || { printf 'check-machine-backend: leaf count = %s, want 1\n' "$leaf_count" >&2; exit 1; } ;;
	machine\ backend:\ format=elf-arm64*) [ "$leaf_count" -eq 0 ] || { printf '%s\n' 'check-machine-backend: Darwin leaf leaked into ELF' >&2; exit 1; }; exit 0 ;;
	*) printf '%s\n' 'check-machine-backend: unexpected checker report' >&2; exit 1 ;;
esac

size="$(printf '%s\n' "$symbols" | awk -v leaf="$leaf" '$NF==leaf{print $2}')"
[ -n "$size" ] && [ "$size" -le 262144 ] || { printf 'check-machine-backend: leaf size %s exceeds 256 KiB\n' "${size:-missing}" >&2; exit 1; }

if go tool objdump -s "$leaf" "$binary" | awk '
{
	for (i = 1; i <= NF; i++) {
		if ($i ~ /^(CALL|BL|BLR|JAL|JALR)$/) {
			print "check-machine-backend: forbidden call instruction: " $0 > "/dev/stderr"
			bad = 1
		}
	}
}
END { exit bad }
'; then :; else exit 1; fi

if [ "$mode" = native ]; then
	[ "$(go env GOOS)/$(go env GOARCH)" = darwin/arm64 ] || { printf '%s\n' 'check-machine-backend: native mode requires darwin/arm64' >&2; exit 2; }
	command -v otool >/dev/null 2>&1 || { printf '%s\n' 'check-machine-backend: otool is required in native mode' >&2; exit 2; }
	otool -l "$binary" | awk '
	$1 == "initprot" && index($0, "rwx") { print "check-machine-backend: otool found W+X segment" > "/dev/stderr"; bad = 1 }
	END { exit bad }
	'
fi
