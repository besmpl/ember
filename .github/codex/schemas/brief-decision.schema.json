{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision", "summary", "reasons", "requested_changes"],
  "properties": {
    "decision": {
      "type": "string",
      "enum": ["APPROVE", "CHANGE", "REJECT"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "requested_changes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}

